2	y
3	z
SELECT DISTINCT b, c FROM t5 ORDER BY b,c;
b	c
1	x
1	y
1	z
2	x
2	y
SELECT DISTINCT MOD(num,2) AS mod2 FROM t6 ORDER BY mod2;
mod2
0
1
