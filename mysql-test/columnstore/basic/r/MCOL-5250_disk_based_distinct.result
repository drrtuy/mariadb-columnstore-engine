16
SELECT DISTINCT a.id, a.val, b.extra
FROM t7a a JOIN t7b b ON a.id = b.id
ORDER BY a.id, b.extra;
id	val	extra
1	100	10
2	200	20
SELECT DISTINCT cat FROM t8 ORDER BY cat LIMIT 2;
cat
A
B
SELECT DISTINCT id, cat FROM t8 WHERE id > 1 ORDER BY id;
id	cat
2	B
3	A
4	C
