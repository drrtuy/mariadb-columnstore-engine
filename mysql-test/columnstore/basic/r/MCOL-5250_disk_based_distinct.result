name
aa
ab
ac
ad
ae
SELECT DISTINCT name FROM t3 ORDER BY name LIMIT 2;
name
aa
ab
SELECT DISTINCT 1 FROM t3 LIMIT 3;
1
1
SELECT DISTINCT t1.col1 FROM t1 JOIN t4 ON t1.col1 = t4.col1 ORDER BY t1.col1;
col1
