SELECT calShowPartitions('tdt','dt');
calShowPartitions('tdt','dt')
Part#     Min                           Max                           Status
  0.0.1     N/A                           N/A                           Enabled
# Test with TIMESTAMP
CREATE TABLE tts (ts TIMESTAMP) ENGINE=ColumnStore;
